# БЛОК ОПРЕДЕЛЕНИЯ СИСТЕМНЫХ ЗАВИСИМОСТЕЙ
{ pkgs }: {
  # pkgs - набор пакетов, предоставляемых средой Nix в Replit
  deps = [
     # Список системных зависимостей, необходимых для работы проекта
    pkgs.replitPackages.prybar-python310
    # Инструмент prybar для запуска Python 3.10 в изолированном окружении Replit
    # Управляет процессами интерпретатора и обеспечивает интеграцию с платформой
    pkgs.replitPackages.stderred
    # Модуль stderred для работы со стандартным потоком ошибок
    # Перенаправляет stderr для отображения диагностических сообщений в консоли Replit
  ];
}